{
  "env": {
    "OMBRE_HOOK_URL": "https://xiclaude.zeabur.app"
  },
  "mcpServers": {
    "rhysen": {
      "url": "https://rcommunity-v2.rhysen.love/mcp?token=bc1e3673b59e71aa74cb2ce5090e70ca354d2e4f3595e3466db647077771791b"
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/session_breath.py\"",
            "shell": "/bin/bash",
            "timeout": 12,
            "statusMessage": "Ombre Brain 正在浮现记忆..."
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/session_breath.py\"",
            "shell": "/bin/bash",
            "timeout": 12,
            "statusMessage": "Ombre Brain 正在浮现记忆..."
          }
        ]
      }
    ]
  }
}
